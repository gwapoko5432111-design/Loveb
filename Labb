<!DOCTYPE html>
<html>
<head>
  <title>Do you love me? ❤️</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      background: #ffe6f0;
      margin: 0;
      height: 100vh;
      overflow: hidden;
    }
    h1 { color: #ff1a75; font-size: 40px; margin-top: 50px; }
    button {
      font-size: 20px;
      padding: 10px 20px;
      border-radius: 10px;
      border: none;
      cursor: pointer;
      transition: transform 0.2s;
    }
    #yes { background-color: #ff66b3; color: white; margin: 20px; }
    #no { background-color: #ff1a75; color: white; position: absolute; }
    #popup {
      display: none;
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      background: #ffb3d9;
      padding: 30px;
      border-radius: 20px;
      font-size: 25px;
      color: #fff;
      box-shadow: 0 0 20px rgba(0,0,0,0.3);
    }
  </style>
</head>
<body>

<h1>Do you love me? ❤️</h1>
<button id="yes">Yes 💖</button>
<button id="no">No 😅</button>

<div id="popup">Yay! You clicked YES! I love you 💕</div>

<script>
const noBtn = document.getElementById("no");
const yesBtn = document.getElementById("yes");
const popup = document.getElementById("popup");

noBtn.addEventListener("mouseover", function() {
  let x = Math.random() * (window.innerWidth - noBtn.offsetWidth);
  let y = Math.random() * (window.innerHeight - noBtn.offsetHeight);
  noBtn.style.left = x + "px";
  noBtn.style.top = y + "px";
  noBtn.style.transform = "rotate(" + (Math.random()*30-15) + "deg)";
});

yesBtn.addEventListener("click", function() {
  popup.style.display = "block";
  noBtn.style.display = "none";
  document.body.style.background = "#ff99cc";
});
</script>

</body>
</html>
